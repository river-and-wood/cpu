# JAL, JALR, AUIPC.
# 每行格式：机器码  # PC: 原始指令
008002ef  # 0x00000000: jal x5,8  # -> 0x00000008
00100093  # 0x00000004: addi x1,x0,1
00900093  # 0x00000008: addi x1,x0,9
01800113  # 0x0000000c: addi x2,x0,24
00010367  # 0x00000010: jalr x6,0(x2)
00100193  # 0x00000014: addi x3,x0,1
00900193  # 0x00000018: addi x3,x0,9
00001397  # 0x0000001c: auipc x7,0x1
00000073  # 0x00000020: ecall
