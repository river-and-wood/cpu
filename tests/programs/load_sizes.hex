# Byte and halfword load/store, signed and unsigned variants.
# 每行格式：机器码  # PC: 原始指令
fff00093  # 0x00000000: addi x1,x0,-1
04000293  # 0x00000004: addi x5,x0,64
0012a023  # 0x00000008: sw x1,0(x5)
00028103  # 0x0000000c: lb x2,0(x5)
0002c183  # 0x00000010: lbu x3,0(x5)
00029203  # 0x00000014: lh x4,0(x5)
0002d303  # 0x00000018: lhu x6,0(x5)
03400393  # 0x0000001c: addi x7,x0,52
007280a3  # 0x00000020: sb x7,1(x5)
0012c403  # 0x00000024: lbu x8,1(x5)
12300493  # 0x00000028: addi x9,x0,291
00929123  # 0x0000002c: sh x9,2(x5)
0022d503  # 0x00000030: lhu x10,2(x5)
00000073  # 0x00000034: ecall
