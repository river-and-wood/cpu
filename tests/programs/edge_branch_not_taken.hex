# Branch not-taken paths.
# 每行格式：机器码  # PC: 原始指令
00100093  # 0x00000000: addi x1,x0,1
00200113  # 0x00000004: addi x2,x0,2
00208463  # 0x00000008: beq x1,x2,8  # -> 0x00000010
00700193  # 0x0000000c: addi x3,x0,7
00109463  # 0x00000010: bne x1,x1,8  # -> 0x00000018
00800213  # 0x00000014: addi x4,x0,8
00000073  # 0x00000018: ecall
